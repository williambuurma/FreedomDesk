# FreedomDesk local / server environment
# Copy to .env and fill in values. Never commit real secrets.

# Express server
PORT=5500
HOST=127.0.0.1

# Public HTTPS base URL for Twilio webhooks (ngrok / tunnel / deployed host).
# Example: https://voice.freedomdeskai.com
PUBLIC_BASE_URL=https://voice.freedomdeskai.com

# Twilio (required to connect a real phone number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: override Aly's Twilio <Say> voice (default: Polly.Joanna-Generative)
# TWILIO_SAY_VOICE=

# Phone voice transport — leave unset or "gather_say" for legacy Gather/Say (default).
# Set to "conversation_relay" to use Twilio ConversationRelay + ElevenLabs TTS.
# PHONE_VOICE_TRANSPORT=conversation_relay

# ConversationRelay / ElevenLabs (non-secret). Canonical Aly voice: Amber King.
# Twilio synthesizes via ConversationRelay — no direct ElevenLabs API key required.
# Voice attribute form: {id}-{model}-{speed}_{stability}_{similarity}
# CONVERSATION_RELAY_TTS_PROVIDER=ElevenLabs
# CONVERSATION_RELAY_VOICE_ID=F89WkXaQbUlVyNvtlD3X
# CONVERSATION_RELAY_VOICE_MODEL=flash_v2_5
# CONVERSATION_RELAY_VOICE_SPEED=0.97
# CONVERSATION_RELAY_VOICE_STABILITY=0.40
# CONVERSATION_RELAY_VOICE_SIMILARITY=0.88

# Hybrid Conversational Aly — OpenAI articulates spoken wording only.
# Deterministic selectNextAsk / safety / persistence remain authoritative.
# Without OPENAI_API_KEY, phone stays on the deterministic speech path.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# HYBRID_CONVERSATIONAL_ALY=1
# HYBRID_ALY_TIMEOUT_MS=2200

# Existing lead capture (unchanged)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_TABLE=
# RESEND_API_KEY=
# FROM_EMAIL=
# NOTIFY_EMAIL=
# REPLY_TO_EMAIL=
# LEADS_PROVIDER=
# ALLOWED_ORIGIN=
