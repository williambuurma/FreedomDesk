# Server (local dev)
PORT=5500
NODE_ENV=development

# Vercel production: set NODE_ENV=production in Vercel dashboard

# Lead storage: supabase | airtable | both
LEADS_PROVIDER=supabase

# Supabase (recommended)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_TABLE=leads

# Airtable (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Leads

# Email via Resend (https://resend.com)
RESEND_API_KEY=
FROM_EMAIL=FreedomDesk <onboarding@yourdomain.com>
REPLY_TO_EMAIL=support@yourdomain.com
NOTIFY_EMAIL=team@yourdomain.com

# CORS (optional — set to your production domain)
ALLOWED_ORIGIN=*
