# FreedomDesk local / server environment
# Copy to .env and fill in values. Never commit real secrets.

# Express server
PORT=5500
HOST=127.0.0.1

# Public HTTPS base URL for Twilio webhooks (ngrok / tunnel / deployed host).
# Example: https://abc123.ngrok-free.app
PUBLIC_BASE_URL=

# Twilio (required to connect a real phone number)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: override Aly's Twilio <Say> voice (default: Google.en-US-Chirp3-HD-Aoede)
# TWILIO_SAY_VOICE=

# Existing lead capture (unchanged)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_TABLE=
# RESEND_API_KEY=
# FROM_EMAIL=
# NOTIFY_EMAIL=
# REPLY_TO_EMAIL=
# LEADS_PROVIDER=
# ALLOWED_ORIGIN=
